---
import { metiers } from '../data/metiers'
import { villes } from '../data/villes'

const villesCol = villes.slice(0, 10)
---

<footer class="site-footer" style="padding-top:5rem;padding-bottom:0;">
  <div class="container">
    <div style="display:grid;grid-template-columns:1fr;gap:3rem;margin-bottom:4rem;" class="footer-grid">

      <!-- Col 1: Brand -->
      <div>
        <a href="/" style="display:flex;align-items:center;gap:.75rem;text-decoration:none;margin-bottom:1.25rem;">
          <div style="width:42px;height:42px;border-radius:.5rem;background:linear-gradient(135deg,#00e5ff,#0066ff);display:flex;align-items:center;justify-content:center;">
            <svg width="22" height="22" fill="none" viewBox="0 0 32 32"><path d="M4 28V12L16 4l12 8v16H4z" fill="rgba(10,15,30,.9)"/><path d="M4 28V12L16 4l12 8v16" stroke="white" stroke-width="1.5" fill="none"/></svg>
          </div>
          <div>
            <div style="font-size:1.1rem;font-weight:900;color:white;letter-spacing:-.02em;">MERIDIAN</div>
            <div style="font-size:.65rem;font-weight:300;color:rgba(255,255,255,.5);letter-spacing:.12em;text-transform:uppercase;">GROUPE</div>
          </div>
        </a>
        <p style="color:rgba(255,255,255,.55);font-size:.875rem;line-height:1.7;max-width:280px;margin-bottom:1.5rem;">
          Bâtisseurs de l'Occitanie depuis 1998. Groupe BTP multi-activités, 45 collaborateurs, 20 villes desservies.
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
          <span class="certif-badge">
            <svg width="10" height="10" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/></svg>
            RGE
          </span>
          <span class="certif-badge">
            <svg width="10" height="10" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/></svg>
            Qualibat
          </span>
          <span class="certif-badge">
            <svg width="10" height="10" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Décennale
          </span>
          <span class="certif-badge">
            <svg width="10" height="10" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/></svg>
            Dommages-ouvrage
          </span>
        </div>
      </div>

      <!-- Col 2: Métiers -->
      <div>
        <h3 style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;color:var(--cyan);margin-bottom:1.25rem;">Nos Métiers</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem;">
          {metiers.map(m => (
            <li>
              <a href={`/metiers/${m.slug}`} style="color:rgba(255,255,255,.55);font-size:.875rem;text-decoration:none;transition:color .2s;display:flex;align-items:center;gap:.5rem;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,.55)'">
                <svg width="10" height="10" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24" style="flex-shrink:0;"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                {m.nom}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 3: Zones -->
      <div>
        <h3 style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;color:var(--cyan);margin-bottom:1.25rem;">Nos Zones</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem;">
          {villesCol.map(v => (
            <li>
              <a href={`/villes/${v.slug}`} style="color:rgba(255,255,255,.55);font-size:.875rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,.55)'">
                {v.nom}
              </a>
            </li>
          ))}
          <li><a href="/contact" style="color:var(--cyan);font-size:.875rem;text-decoration:none;font-weight:600;">Voir toutes les villes →</a></li>
        </ul>
      </div>

      <!-- Col 4: Entreprise -->
      <div>
        <h3 style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;color:var(--cyan);margin-bottom:1.25rem;">Entreprise</h3>
        <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:.5rem;">
          {[
            { href: '/notre-groupe', label: 'Notre histoire' },
            { href: '/notre-groupe#valeurs', label: 'Nos valeurs' },
            { href: '/notre-groupe#equipe', label: 'Notre équipe' },
            { href: '/notre-groupe#certifications', label: 'Certifications' },
            { href: '/realisations', label: 'Nos réalisations' },
            { href: '/recrutement', label: 'Recrutement' },
            { href: '/blog', label: 'Blog Expert' },
          ].map(l => (
            <li>
              <a href={l.href} style="color:rgba(255,255,255,.55);font-size:.875rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,.55)'">{l.label}</a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Col 5: Contact + Newsletter -->
      <div>
        <h3 style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;color:var(--cyan);margin-bottom:1.25rem;">Contact</h3>
        <div style="display:flex;flex-direction:column;gap:.875rem;margin-bottom:2rem;">
          <a href="tel:0467000000" style="display:flex;align-items:center;gap:.75rem;color:rgba(255,255,255,.7);font-size:.875rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,.7)'">
            <span style="width:32px;height:32px;background:rgba(0,229,255,.1);border-radius:.5rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="14" height="14" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 15.5a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 4.8h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L7.91 12.1a16 16 0 006 6l.9-.9a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 19.43z"/></svg>
            </span>
            04 67 00 00 00
          </a>
          <a href="mailto:contact@meridian-groupe.fr" style="display:flex;align-items:center;gap:.75rem;color:rgba(255,255,255,.7);font-size:.875rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,.7)'">
            <span style="width:32px;height:32px;background:rgba(0,229,255,.1);border-radius:.5rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="14" height="14" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </span>
            contact@meridian-groupe.fr
          </a>
          <div style="display:flex;align-items:flex-start;gap:.75rem;color:rgba(255,255,255,.7);font-size:.875rem;">
            <span style="width:32px;height:32px;background:rgba(0,229,255,.1);border-radius:.5rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px;">
              <svg width="14" height="14" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            Montpellier, 34000<br/>Occitanie, France
          </div>
        </div>
        <div>
          <p style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.15em;color:rgba(255,255,255,.5);margin-bottom:.75rem;">Newsletter</p>
          <form style="display:flex;gap:.5rem;" onsubmit="return false;">
            <input type="email" placeholder="Votre email" style="flex:1;padding:.625rem .875rem;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.15);border-radius:.5rem;color:white;font-size:.8125rem;outline:none;" />
            <button type="submit" style="padding:.625rem 1rem;background:linear-gradient(135deg,#00e5ff,#0066ff);color:#0a0f1e;font-weight:700;font-size:.75rem;border:none;border-radius:.5rem;cursor:pointer;white-space:nowrap;">OK</button>
          </form>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div style="border-top:1px solid rgba(255,255,255,.08);padding:1.5rem 0;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;">
      <p style="color:rgba(255,255,255,.35);font-size:.75rem;">
        © 2024 Meridian Groupe · Tous droits réservés ·
        <span style="color:rgba(255,255,255,.2);">Template D1 PRESTIGE by</span>
        <span style="background:linear-gradient(135deg,#00e5ff,#0066ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;font-weight:700;"> WebTrafic</span>
      </p>
      <div style="display:flex;align-items:center;gap:1.5rem;">
        <a href="/mentions-legales" style="color:rgba(255,255,255,.35);font-size:.75rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='rgba(255,255,255,.6)'" onmouseout="this.style.color='rgba(255,255,255,.35)'">Mentions légales</a>
        <a href="/cgv" style="color:rgba(255,255,255,.35);font-size:.75rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='rgba(255,255,255,.6)'" onmouseout="this.style.color='rgba(255,255,255,.35)'">CGV</a>
        <a href="/contact" style="color:rgba(255,255,255,.35);font-size:.75rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='rgba(255,255,255,.6)'" onmouseout="this.style.color='rgba(255,255,255,.35)'">Contact</a>
      </div>
    </div>
  </div>
</footer>

<style>
@media (min-width: 640px) {
  .footer-grid { grid-template-columns: 1fr 1fr !important; }
}
@media (min-width: 1024px) {
  .footer-grid { grid-template-columns: 2fr 1fr 1fr 1fr 1.5fr !important; }
}
</style>
