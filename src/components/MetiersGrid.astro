---
---
<section class="section" style="background:#f8fafc;overflow:hidden;">
  <div class="container">
    <!-- Header -->
    <div style="text-align:center;margin-bottom:3.5rem;" class="reveal-element">
      <div class="section-label" style="justify-content:center;">Expertise pluridisciplinaire</div>
      <h2 style="font-size:clamp(2rem,4vw,3rem);font-weight:800;color:#0f172a;margin:0 auto;max-width:600px;">
        8 métiers,<br/>
        <span style="background:linear-gradient(135deg,#00e5ff,#0066ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">1 seul groupe</span>
      </h2>
      <p style="color:#374151;max-width:520px;margin:1.25rem auto 0;font-size:1.0625rem;">
        De la fondation à la finition, Meridian Groupe pilote l'intégralité de vos travaux avec un seul interlocuteur.
      </p>
    </div>

    <!-- Masonry-style grid -->
    <div style="display:grid;grid-template-columns:1fr;gap:1rem;" class="metiers-grid">

      <!-- Large card left: Construction -->
      <div class="metier-card reveal-element" style="grid-row:span 2;min-height:480px;">
        <img src="https://images.unsplash.com/photo-1503387762-592deb58ef4e?w=800&q=85" alt="Construction neuve Occitanie" loading="lazy" />
        <div class="metier-card-overlay"></div>
        <div class="metier-card-content">
          <span style="display:inline-block;padding:.25rem .75rem;background:rgba(0,229,255,.15);border:1px solid rgba(0,229,255,.3);border-radius:9999px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cyan);margin-bottom:.75rem;">Construction</span>
          <h3 style="color:white;font-size:1.625rem;font-weight:700;margin:0 0 .625rem;line-height:1.2;">Construction neuve</h3>
          <p style="color:rgba(255,255,255,.65);font-size:.875rem;margin:0 0 1rem;line-height:1.6;">Maisons individuelles, immeubles et bâtiments tertiaires : maîtrise d'ouvrage complète de A à Z.</p>
          <a href="/metiers/construction" style="color:white;font-size:.875rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.375rem;transition:gap .2s;" onmouseover="this.style.gap='.625rem';this.style.color='var(--cyan)'" onmouseout="this.style.gap='.375rem';this.style.color='white'">
            Découvrir <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Rénovation -->
      <div class="metier-card reveal-element delay-100" style="min-height:230px;">
        <img src="https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=600&q=80" alt="Rénovation Occitanie" loading="lazy" />
        <div class="metier-card-overlay"></div>
        <div class="metier-card-content">
          <span style="display:inline-block;padding:.2rem .625rem;background:rgba(0,229,255,.15);border:1px solid rgba(0,229,255,.3);border-radius:9999px;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cyan);margin-bottom:.5rem;">Rénovation</span>
          <h3 style="color:white;font-size:1.25rem;font-weight:700;margin:0 0 .5rem;">Rénovation complète</h3>
          <a href="/metiers/renovation" style="color:white;font-size:.8125rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.375rem;transition:color .2s;" onmouseover="this.style.color='var(--cyan)'" onmouseout="this.style.color='white'">
            Découvrir <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Isolation -->
      <div class="metier-card reveal-element delay-200" style="min-height:230px;">
        <img src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=600&q=80" alt="Isolation thermique Occitanie" loading="lazy" />
        <div class="metier-card-overlay"></div>
        <div class="metier-card-content">
          <span style="display:inline-block;padding:.2rem .625rem;background:rgba(0,229,255,.15);border:1px solid rgba(0,229,255,.3);border-radius:9999px;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cyan);margin-bottom:.5rem;">Isolation</span>
          <h3 style="color:white;font-size:1.25rem;font-weight:700;margin:0 0 .5rem;">Isolation thermique</h3>
          <a href="/metiers/isolation" style="color:white;font-size:.8125rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.375rem;transition:color .2s;" onmouseover="this.style.color='var(--cyan)'" onmouseout="this.style.color='white'">
            Découvrir <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Peinture -->
      <div class="metier-card reveal-element delay-200" style="min-height:230px;">
        <img src="https://images.unsplash.com/photo-1589939705384-5185137a7f0f?w=600&q=80" alt="Peinture et revêtements" loading="lazy" />
        <div class="metier-card-overlay"></div>
        <div class="metier-card-content">
          <span style="display:inline-block;padding:.2rem .625rem;background:rgba(0,229,255,.15);border:1px solid rgba(0,229,255,.3);border-radius:9999px;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cyan);margin-bottom:.5rem;">Peinture</span>
          <h3 style="color:white;font-size:1.25rem;font-weight:700;margin:0 0 .5rem;">Peinture & revêtements</h3>
          <a href="/metiers/peinture" style="color:white;font-size:.8125rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.375rem;transition:color .2s;" onmouseover="this.style.color='var(--cyan)'" onmouseout="this.style.color='white'">
            Découvrir <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Charpente -->
      <div class="metier-card reveal-element delay-300" style="min-height:230px;">
        <img src="https://images.unsplash.com/photo-1416879595882-3373a0480b5b?w=600&q=80" alt="Charpente bois Occitanie" loading="lazy" />
        <div class="metier-card-overlay"></div>
        <div class="metier-card-content">
          <span style="display:inline-block;padding:.2rem .625rem;background:rgba(0,229,255,.15);border:1px solid rgba(0,229,255,.3);border-radius:9999px;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cyan);margin-bottom:.5rem;">Charpente</span>
          <h3 style="color:white;font-size:1.25rem;font-weight:700;margin:0 0 .5rem;">Charpente bois</h3>
          <a href="/metiers/charpente" style="color:white;font-size:.8125rem;font-weight:600;text-decoration:none;display:inline-flex;align-items:center;gap:.375rem;transition:color .2s;" onmouseover="this.style.color='var(--cyan)'" onmouseout="this.style.color='white'">
            Découvrir <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>

      <!-- Large card bottom: Couverture -->
      <div class="metier-card reveal-element delay-300" style="min-height:360px;" class="metiers-full">
        <img src="https://images.unsplash.com/photo-1562516155-e0c1ee44059b?w=800&q=85" alt="Couverture toiture Occitanie" loading="lazy" />
        <div class="metier-card-overlay"></div>
        <div class="metier-card-content" style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
          <div>
            <span style="display:inline-block;padding:.2rem .625rem;background:rgba(0,229,255,.15);border:1px solid rgba(0,229,255,.3);border-radius:9999px;font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--cyan);margin-bottom:.5rem;">Couverture</span>
            <h3 style="color:white;font-size:1.5rem;font-weight:700;margin:0 0 .5rem;">Couverture & toiture</h3>
            <p style="color:rgba(255,255,255,.65);font-size:.875rem;margin:0;max-width:400px;">Tuiles, ardoises, zinc, bac acier : vos toits entre des mains expertes depuis 1998.</p>
          </div>
          <a href="/metiers/couverture" class="btn-gradient" style="flex-shrink:0;">
            Voir nos prestations
          </a>
        </div>
      </div>
    </div>

    <!-- Link to all services -->
    <div style="text-align:center;margin-top:2.5rem;" class="reveal-element">
      <a href="/metiers/ravalement" style="color:#374151;font-size:.9375rem;font-weight:600;text-decoration:none;margin-right:1.5rem;transition:color .2s;" onmouseover="this.style.color='var(--electric)'" onmouseout="this.style.color='#374151'">Ravalement de façades →</a>
      <a href="/metiers/etancheite" style="color:#374151;font-size:.9375rem;font-weight:600;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='var(--electric)'" onmouseout="this.style.color='#374151'">Étanchéité →</a>
    </div>
  </div>
</section>

<style>
@media(min-width:768px){
  .metiers-grid {
    grid-template-columns: 1fr 1fr !important;
  }
  .metiers-grid > *:first-child {
    grid-row: span 2;
  }
  .metiers-full {
    grid-column: span 2;
  }
}
@media(min-width:1024px){
  .metiers-grid {
    grid-template-columns: 2fr 1fr 1fr !important;
  }
}
</style>
