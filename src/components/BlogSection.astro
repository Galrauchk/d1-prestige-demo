---
import { articles } from '../data/blog'
const featured = articles.find(a => a.featured)!
const secondary = articles.filter(a => !a.featured).slice(0, 3)
---

<section class="section" style="background:white;">
  <div class="container">
    <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:2rem;margin-bottom:3rem;" class="reveal-element">
      <div>
        <div class="section-label">Conseils d'experts</div>
        <h2 style="font-size:clamp(1.875rem,3.5vw,2.75rem);font-weight:800;color:#0f172a;margin:0;">
          Le blog <span style="background:linear-gradient(135deg,#00e5ff,#0066ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Meridian</span>
        </h2>
      </div>
      <a href="/blog" class="btn-ghost-dark">Tous les articles →</a>
    </div>

    <div style="display:grid;grid-template-columns:1fr;gap:2rem;" class="blog-grid">

      <!-- Featured article -->
      <article class="reveal-element" style="display:flex;flex-direction:column;border-radius:1.25rem;overflow:hidden;background:#f8fafc;transition:transform .3s,box-shadow .3s;" onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 20px 60px rgba(0,0,0,.1)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
        <div style="overflow:hidden;flex-shrink:0;height:280px;">
          <img src={featured.image} alt={featured.titre} loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform .6s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform=''"/>
        </div>
        <div style="padding:2rem;flex:1;display:flex;flex-direction:column;">
          <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1rem;">
            <span style="padding:.25rem .75rem;background:linear-gradient(135deg,rgba(0,229,255,.1),rgba(0,102,255,.08));border:1px solid rgba(0,229,255,.2);border-radius:9999px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--electric);">{featured.categorie}</span>
            <span style="font-size:.8rem;color:#94a3b8;">{featured.tempsLecture} min de lecture</span>
          </div>
          <h3 class="h2-serif" style="font-size:clamp(1.25rem,2.5vw,1.75rem);color:#0f172a;margin:0 0 .875rem;line-height:1.3;">
            <a href={`/blog/${featured.slug}`} style="text-decoration:none;color:inherit;transition:color .2s;" onmouseover="this.style.color='var(--electric)'" onmouseout="this.style.color='inherit'">{featured.titre}</a>
          </h3>
          <p style="color:#374151;font-size:.9375rem;line-height:1.7;margin:0 0 1.5rem;flex:1;">{featured.extrait}</p>
          <div style="display:flex;align-items:center;justify-content:space-between;">
            <div style="display:flex;align-items:center;gap:.75rem;">
              <img src={featured.auteurPhoto} alt={featured.auteur} loading="lazy" style="width:36px;height:36px;border-radius:50%;object-fit:cover;" />
              <div>
                <div style="font-size:.8125rem;font-weight:600;color:#0f172a;">{featured.auteur}</div>
                <div style="font-size:.75rem;color:#94a3b8;">{featured.date}</div>
              </div>
            </div>
            <a href={`/blog/${featured.slug}`} style="font-size:.875rem;font-weight:700;color:var(--electric);text-decoration:none;display:flex;align-items:center;gap:.375rem;transition:gap .2s;" onmouseover="this.style.gap='.625rem'" onmouseout="this.style.gap='.375rem'">
              Lire <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      </article>

      <!-- Secondary articles -->
      <div style="display:flex;flex-direction:column;gap:1.5rem;">
        {secondary.map((art, i) => (
          <article class="reveal-element" style={`display:flex;gap:1.25rem;padding:1.25rem;background:#f8fafc;border-radius:.875rem;transition:all .3s;transition-delay:${(i+1)*100}ms;`} onmouseover="this.style.background='#f0f9ff';this.style.transform='translateX(4px)'" onmouseout="this.style.background='#f8fafc';this.style.transform=''">
            <a href={`/blog/${art.slug}`} style="flex-shrink:0;width:90px;height:90px;border-radius:.625rem;overflow:hidden;display:block;">
              <img src={art.image} alt={art.titre} loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform .3s;" onmouseover="this.style.transform='scale(1.08)'" onmouseout="this.style.transform=''"/>
            </a>
            <div style="flex:1;min-width:0;">
              <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:.375rem;">
                <span style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:var(--electric);">{art.categorie}</span>
                <span style="color:#e2e8f0;">·</span>
                <span style="font-size:.75rem;color:#94a3b8;">{art.tempsLecture} min</span>
              </div>
              <h4 style="font-size:.9375rem;font-weight:700;color:#0f172a;margin:0 0 .375rem;line-height:1.4;">
                <a href={`/blog/${art.slug}`} style="text-decoration:none;color:inherit;transition:color .2s;" onmouseover="this.style.color='var(--electric)'" onmouseout="this.style.color='inherit'">{art.titre}</a>
              </h4>
              <p style="font-size:.8125rem;color:#94a3b8;margin:0;">{art.date}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
@media(min-width:1024px){
  .blog-grid { grid-template-columns: 3fr 2fr !important; }
  .blog-grid > article:first-child img { height: 320px !important; }
}
</style>
