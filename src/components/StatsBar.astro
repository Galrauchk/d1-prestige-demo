---
const stats = [
  { count: 2400, suffix: '+', label: 'Chantiers réalisés', decimal: false },
  { count: 45, suffix: '', label: 'Collaborateurs', decimal: false },
  { count: 26, suffix: ' ans', label: "D'expérience", decimal: false },
  { count: 20, suffix: '', label: 'Villes desservies', decimal: false },
  { count: 98, suffix: '%', label: 'Clients satisfaits', decimal: false },
]
---

<section style="background:linear-gradient(135deg,#00e5ff,#0066ff);position:relative;overflow:hidden;">
  <!-- Decorative diagonal divider top -->
  <div style="position:absolute;top:0;left:0;right:0;height:60px;overflow:hidden;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="width:100%;height:60px;display:block;" xmlns="http://www.w3.org/2000/svg">
      <polygon points="0,0 1440,60 1440,0" fill="#0a0f1e" opacity=".8"/>
    </svg>
  </div>

  <div class="container" style="padding-top:4rem;padding-bottom:4rem;position:relative;z-index:1;">
    <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;" class="stats-grid">
      {stats.map((s, i) => (
        <div class="reveal-element" style={`transition-delay:${i*80}ms;text-align:center;position:relative;`}>
          {i < stats.length - 1 && (
            <div style="display:none;" class="stats-sep"></div>
          )}
          <div
            data-count={s.count}
            data-suffix={s.suffix}
            data-decimal={s.decimal}
            style="font-family:'Inter',sans-serif;font-weight:900;font-size:clamp(2.5rem,5vw,4rem);color:#0a0f1e;line-height:1;"
          >0{s.suffix}</div>
          <div style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:rgba(10,15,30,.65);margin-top:.375rem;">{s.label}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- Decorative diagonal divider bottom -->
  <div style="position:absolute;bottom:0;left:0;right:0;height:60px;overflow:hidden;">
    <svg viewBox="0 0 1440 60" preserveAspectRatio="none" style="width:100%;height:60px;display:block;" xmlns="http://www.w3.org/2000/svg">
      <polygon points="0,60 1440,0 1440,60" fill="#f8fafc"/>
    </svg>
  </div>
</section>

<style>
@media(min-width:640px){ .stats-grid { grid-template-columns: repeat(3,1fr) !important; } }
@media(min-width:1024px){ .stats-grid { grid-template-columns: repeat(5,1fr) !important; } }
.stats-sep {
  position:absolute; right:0; top:20%; bottom:20%;
  width:1px; background:rgba(10,15,30,.15);
}
@media(min-width:1024px){ .stats-sep { display:block !important; } }
</style>
