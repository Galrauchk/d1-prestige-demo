---
---
<section style="position:relative;height:100vh;min-height:600px;max-height:1000px;overflow:hidden;display:flex;align-items:flex-end;">
  <!-- Background Image with parallax -->
  <div style="position:absolute;inset:0;z-index:0;">
    <img
      src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1920&q=90"
      alt="Chantier Meridian Groupe — construction en Occitanie"
      class="hero-parallax-img"
      style="width:100%;height:110%;object-fit:cover;object-position:center;will-change:transform;"
      fetchpriority="high"
      decoding="async"
    />
  </div>

  <!-- Overlay -->
  <div class="hero-overlay noise-overlay" style="z-index:1;"></div>

  <!-- Content -->
  <div class="container" style="position:relative;z-index:2;padding-bottom:clamp(4rem,10vh,8rem);width:100%;">
    <div style="max-width:680px;">

      <!-- Shimmer badge -->
      <div class="shimmer-badge reveal-element" style="margin-bottom:1.75rem;display:inline-flex;">
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
        Groupe BTP Occitanie &nbsp;•&nbsp; Depuis 1998 &nbsp;•&nbsp; RGE Qualibat
      </div>

      <!-- H1 -->
      <h1 class="reveal-element delay-100" style="color:white;margin:0 0 1.5rem;font-size:clamp(3rem,6vw,5.5rem);font-weight:900;line-height:1.05;letter-spacing:-.02em;">
        Bâtisseurs<br/>
        <span style="background:linear-gradient(135deg,#00e5ff,#0066ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;">d'Occitanie</span><br/>
        depuis 26 ans
      </h1>

      <!-- Subtitle -->
      <p class="reveal-element delay-200" style="color:rgba(255,255,255,.75);font-size:1.125rem;max-width:560px;margin:0 0 2.5rem;line-height:1.7;">
        Construction, rénovation, isolation, couverture… Meridian Groupe orchestre chaque chantier avec rigueur et passion, de Montpellier à toute l'Occitanie.
      </p>

      <!-- CTAs -->
      <div class="reveal-element delay-300" style="display:flex;flex-wrap:wrap;align-items:center;gap:1rem;margin-bottom:3rem;">
        <a href="/devis" class="btn-gradient magnetic-btn">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Devis gratuit 48h
        </a>
        <a href="/realisations" class="btn-outline">
          Nos réalisations
        </a>
        <a href="#video" style="display:inline-flex;align-items:center;gap:.625rem;color:rgba(255,255,255,.8);font-size:.9375rem;font-weight:500;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,.8)'">
          <span style="width:40px;height:40px;border:2px solid rgba(255,255,255,.4);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:border-color .2s;">
            <svg width="12" height="12" fill="white" viewBox="0 0 24 24"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          </span>
          Vidéo entreprise
        </a>
      </div>

      <!-- Trust badges -->
      <div class="reveal-element delay-400" style="display:flex;flex-wrap:wrap;gap:.75rem;">
        {[
          { icon: '👥', value: '45', label: 'collaborateurs' },
          { icon: '📅', value: '26 ans', label: "d'expérience" },
          { icon: '💶', value: '8M€', label: "de CA" },
          { icon: '✅', value: 'Certifié', label: 'RGE' },
        ].map(b => (
          <div class="trust-badge">
            <span style="font-size:1.1rem;">{b.icon}</span>
            <div>
              <div style="font-size:.8125rem;font-weight:800;color:white;line-height:1.2;">{b.value}</div>
              <div style="font-size:.65rem;color:rgba(255,255,255,.5);text-transform:uppercase;letter-spacing:.05em;">{b.label}</div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="scroll-indicator reveal-element delay-500" style="position:absolute;right:2.5rem;bottom:0;">
      <div class="scroll-indicator-line"></div>
      <div class="scroll-indicator-dot"></div>
    </div>
  </div>
</section>
