---
---
<section style="position:relative;overflow:hidden;background:var(--navy);">
  <!-- Background image -->
  <div style="position:absolute;inset:0;z-index:0;">
    <img
      src="https://images.unsplash.com/photo-1504307651254-35680f356dfd?w=1600&q=80"
      alt=""
      loading="lazy"
      aria-hidden="true"
      style="width:100%;height:100%;object-fit:cover;opacity:.2;"
    />
  </div>
  <!-- Gradient mesh -->
  <div class="gradient-mesh" style="z-index:1;"></div>

  <div class="container" style="position:relative;z-index:2;padding-top:6rem;padding-bottom:6rem;">
    <div style="max-width:680px;margin:0 auto;text-align:center;">

      <div class="shimmer-badge reveal-element" style="margin:0 auto 1.75rem;display:inline-flex;justify-content:center;">
        Réponse garantie sous 48h ouvrées
      </div>

      <h2 class="h2-serif reveal-element delay-100" style="color:white;font-size:clamp(2rem,5vw,3.5rem);margin:0 0 1.25rem;">
        Un projet ? Parlons-en.
      </h2>
      <p class="reveal-element delay-200" style="color:rgba(255,255,255,.7);font-size:1.0625rem;margin:0 0 3rem;max-width:500px;margin-left:auto;margin-right:auto;line-height:1.7;">
        Nos équipes sont disponibles du lundi au vendredi, 8h-18h. Devis gratuit, sans engagement, sous 48h.
      </p>

      <!-- Quick form -->
      <form class="reveal-element delay-300" style="display:flex;flex-direction:column;gap:.875rem;max-width:480px;margin:0 auto 3rem;" onsubmit="return false;">
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:.875rem;">
          <input class="cta-input" type="text" placeholder="Votre nom" aria-label="Nom" />
          <input class="cta-input" type="tel" placeholder="Votre téléphone" aria-label="Téléphone" />
        </div>
        <button type="submit" class="btn-gradient" style="width:100%;justify-content:center;padding:1rem 2rem;font-size:1rem;">
          <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          Recevoir mon devis gratuit
        </button>
      </form>

      <!-- Contact info -->
      <div class="reveal-element delay-400" style="display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:2rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,.1);">
        <a href="tel:0467000000" style="display:flex;align-items:center;gap:.625rem;color:rgba(255,255,255,.75);font-size:.9375rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,.75)'">
          <svg width="18" height="18" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 014.69 15.5a19.79 19.79 0 01-3.07-8.67A2 2 0 013.6 4.8h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L7.91 12.1a16 16 0 006 6l.9-.9a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 19.43z"/></svg>
          04 67 00 00 00
        </a>
        <a href="mailto:contact@meridian-groupe.fr" style="display:flex;align-items:center;gap:.625rem;color:rgba(255,255,255,.75);font-size:.9375rem;text-decoration:none;transition:color .2s;" onmouseover="this.style.color='white'" onmouseout="this.style.color='rgba(255,255,255,.75)'">
          <svg width="18" height="18" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          contact@meridian-groupe.fr
        </a>
        <span style="display:flex;align-items:center;gap:.625rem;color:rgba(255,255,255,.75);font-size:.9375rem;">
          <svg width="18" height="18" fill="none" stroke="var(--cyan)" stroke-width="2" viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          Montpellier, 34000
        </span>
      </div>
    </div>
  </div>
</section>
