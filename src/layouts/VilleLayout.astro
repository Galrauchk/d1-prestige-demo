---
import BaseLayout from './BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import CtaSection from '../components/CtaSection.astro'
import { metiers } from '../data/metiers'
import type { Ville } from '../data/villes'

interface Props { ville: Ville }
const { ville } = Astro.props

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": `Meridian Groupe — ${ville.nom}`,
  "description": `Entreprise BTP à ${ville.nom} (${ville.codePostal}). Construction, rénovation, isolation et travaux tous corps d'état. Devis gratuit.`,
  "url": `https://d1-prestige-demo.netlify.app/villes/${ville.slug}`,
  "telephone": "+33-4-67-00-00-00",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": ville.nom,
    "postalCode": ville.codePostal,
    "addressCountry": "FR"
  },
  "geo": { "@type": "GeoCoordinates", "latitude": ville.lat, "longitude": ville.lng },
  "areaServed": { "@type": "City", "name": ville.nom }
})
---

<BaseLayout
  title={`Entreprise BTP ${ville.nom} (${ville.codePostal}) — Meridian Groupe`}
  description={`Meridian Groupe, votre expert BTP à ${ville.nom}. Construction, rénovation, isolation, couverture, ravalement. Intervention sous ${ville.interventionTime}. Devis gratuit 48h.`}
  canonical={`https://d1-prestige-demo.netlify.app/villes/${ville.slug}`}
  schema={schema}
>
  <!-- Page hero -->
  <div class="page-hero">
    <div class="container" style="position:relative;z-index:1;">
      <Breadcrumb items={[{ label: 'Nos zones', href: '/contact' }, { label: ville.nom }]} />
      <div style="max-width:700px;margin-top:2rem;">
        <div class="section-label">{ville.departement} — Intervention {ville.interventionTime}</div>
        <h1 style="color:white;font-size:clamp(2.25rem,5vw,3.75rem);font-weight:900;margin:0 0 1.25rem;line-height:1.1;">
          Entreprise BTP<br/>
          <span style="background:linear-gradient(135deg,#00e5ff,#0066ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">{ville.nom}</span>
        </h1>
        <p style="color:rgba(255,255,255,.75);font-size:1.0625rem;max-width:580px;line-height:1.7;margin:0 0 2rem;">
          {ville.description}
        </p>
        <div style="display:flex;flex-wrap:wrap;gap:1rem;">
          <a href="/devis" class="btn-gradient">Devis gratuit 48h</a>
          <a href="tel:0467000000" class="btn-outline">04 67 00 00 00</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Services grid -->
  <section class="section" style="background:#f8fafc;">
    <div class="container">
      <div style="text-align:center;margin-bottom:3rem;" class="reveal-element">
        <div class="section-label" style="justify-content:center;">Nos prestations</div>
        <h2 style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:800;color:#0f172a;margin:0;">
          Nos services à {ville.nom}
        </h2>
      </div>
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1rem;" class="services-grid">
        {metiers.map((m, i) => (
          <a href={`/metiers/${m.slug}`} class="reveal-element" style={`display:flex;align-items:flex-start;gap:1rem;padding:1.5rem;background:white;border-radius:1rem;border:1.5px solid #f1f5f9;text-decoration:none;transition:all .3s;transition-delay:${i*60}ms;`} onmouseover="this.style.borderColor='var(--cyan)';this.style.transform='translateY(-2px)';this.style.boxShadow='0 8px 30px rgba(0,0,0,.08)'" onmouseout="this.style.borderColor='#f1f5f9';this.style.transform='';this.style.boxShadow=''">
            <span style="width:44px;height:44px;background:linear-gradient(135deg,rgba(0,229,255,.1),rgba(0,102,255,.05));border-radius:.75rem;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
              <svg width="20" height="20" fill="none" stroke="var(--electric)" stroke-width="1.5" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/></svg>
            </span>
            <div>
              <div style="font-weight:700;color:#0f172a;font-size:.9375rem;margin-bottom:.25rem;">{m.nom}</div>
              <div style="font-size:.8125rem;color:#94a3b8;line-height:1.5;">{m.description.slice(0, 70)}…</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Why us in this city -->
  <section class="section" style="background:white;">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr;gap:3rem;align-items:center;" class="why-grid">
        <div class="reveal-element">
          <div class="section-label">Pourquoi Meridian à {ville.nom} ?</div>
          <h2 class="h2-serif" style="font-size:clamp(1.75rem,3.5vw,2.5rem);color:#0f172a;margin:0 0 1.5rem;">
            Votre partenaire BTP de confiance à {ville.nom}
          </h2>
          <p style="color:#374151;line-height:1.75;margin-bottom:1rem;">
            Depuis notre siège de Montpellier, nos équipes interviennent à {ville.nom} dans un délai de {ville.interventionTime}. Notre connaissance du territoire, des matériaux adaptés au climat méditerranéen et des spécificités locales nous permet de vous garantir des travaux durables.
          </p>
          <p style="color:#374151;line-height:1.75;margin-bottom:2rem;">
            Chaque chantier à {ville.nom} bénéficie du même niveau d'exigence que nos projets phares : suivi quotidien, chef de chantier dédié, garantie décennale et satisfaction client à 98%.
          </p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            {[
              { icon: '⚡', title: `Intervention ${ville.interventionTime}`, desc: 'Délai garanti' },
              { icon: '✅', title: 'Devis sous 48h', desc: 'Gratuit, sans engagement' },
              { icon: '🏆', title: 'Garantie décennale', desc: 'Assurance complète' },
              { icon: '👷', title: 'Équipe dédiée', desc: 'Chef de chantier attitré' },
            ].map(item => (
              <div style="padding:1rem;background:#f8fafc;border-radius:.75rem;border:1px solid #f1f5f9;">
                <div style="font-size:1.25rem;margin-bottom:.375rem;">{item.icon}</div>
                <div style="font-weight:700;color:#0f172a;font-size:.875rem;">{item.title}</div>
                <div style="font-size:.75rem;color:#94a3b8;">{item.desc}</div>
              </div>
            ))}
          </div>
        </div>
        <div class="reveal-element delay-200" style="background:linear-gradient(135deg,#0a0f1e,#0d1a3a);border-radius:1.5rem;padding:2.5rem;">
          <h3 style="color:white;font-size:1.25rem;font-weight:700;margin:0 0 1.5rem;">Nos chiffres à {ville.nom}</h3>
          {[
            { val: '150+', label: 'Chantiers réalisés' },
            { val: ville.interventionTime, label: "Délai d'intervention" },
            { val: '26 ans', label: "D'expérience en Occitanie" },
            { val: '98%', label: 'Clients satisfaits' },
          ].map(s => (
            <div style="display:flex;justify-content:space-between;align-items:center;padding:.875rem 0;border-bottom:1px solid rgba(255,255,255,.08);">
              <span style="color:rgba(255,255,255,.65);font-size:.9rem;">{s.label}</span>
              <span style="font-weight:800;font-size:1.125rem;background:linear-gradient(135deg,#00e5ff,#0066ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">{s.val}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>

<style>
@media(min-width:640px){ .services-grid { grid-template-columns: repeat(2,1fr) !important; } }
@media(min-width:1024px){ .services-grid { grid-template-columns: repeat(4,1fr) !important; } .why-grid { grid-template-columns: 3fr 2fr !important; } }
</style>
