---
import BaseLayout from './BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import CtaSection from '../components/CtaSection.astro'
import { villes } from '../data/villes'
import type { Metier } from '../data/metiers'

interface Props { metier: Metier }
const { metier } = Astro.props

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Service",
  "name": metier.nom,
  "provider": {
    "@type": "LocalBusiness",
    "name": "Meridian Groupe",
    "telephone": "+33-4-67-00-00-00",
    "address": { "@type": "PostalAddress", "addressLocality": "Montpellier", "postalCode": "34000", "addressCountry": "FR" }
  },
  "description": metier.descriptionLongue,
  "areaServed": "Occitanie",
  "url": `https://d1-prestige-demo.netlify.app/metiers/${metier.slug}`
})
---

<BaseLayout
  title={`${metier.nom} en Occitanie — Meridian Groupe | Expert BTP`}
  description={`${metier.nom} en Occitanie par Meridian Groupe. ${metier.description} Certifié ${metier.certifications[0]}. Devis gratuit 48h — 04 67 00 00 00.`}
  canonical={`https://d1-prestige-demo.netlify.app/metiers/${metier.slug}`}
  schema={schema}
>
  <!-- Page hero -->
  <div style="position:relative;overflow:hidden;min-height:500px;display:flex;align-items:flex-end;">
    <img src={metier.image} alt={`${metier.nom} — Meridian Groupe`} style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;" loading="eager" fetchpriority="high"/>
    <div style="position:absolute;inset:0;background:linear-gradient(to bottom,rgba(10,15,30,.3) 0%,rgba(10,15,30,.85) 100%);"></div>
    <div class="container" style="position:relative;z-index:1;padding-bottom:4rem;width:100%;">
      <Breadcrumb items={[{ label: 'Nos Métiers' }, { label: metier.nom }]} />
      <div style="max-width:650px;margin-top:1.5rem;">
        <div class="section-label">{metier.certifications.join(' • ')}</div>
        <h1 style="color:white;font-size:clamp(2.25rem,5vw,3.75rem);font-weight:900;margin:0 0 1.25rem;line-height:1.1;">
          {metier.nom}<br/>
          <span style="background:linear-gradient(135deg,#00e5ff,#0066ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">en Occitanie</span>
        </h1>
        <p style="color:rgba(255,255,255,.8);font-size:1.0625rem;margin:0 0 2rem;line-height:1.7;">{metier.description}</p>
        <div style="display:flex;flex-wrap:wrap;gap:1rem;">
          <a href="/devis" class="btn-gradient">Devis gratuit 48h</a>
          <a href="tel:0467000000" class="btn-outline">04 67 00 00 00</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Description -->
  <section class="section" style="background:white;">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr;gap:3rem;" class="metier-detail-grid">
        <div class="reveal-element">
          <div class="section-label">Notre expertise</div>
          <h2 style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:800;color:#0f172a;margin:0 0 1.5rem;">{metier.nom} — Notre approche</h2>
          <p style="color:#374151;line-height:1.8;font-size:1.0625rem;margin-bottom:1.5rem;">{metier.descriptionLongue}</p>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-top:2rem;">
            {metier.prestations.map(p => (
              <div style="display:flex;align-items:center;gap:.625rem;padding:.75rem 1rem;background:#f8fafc;border-radius:.625rem;border:1px solid #f1f5f9;">
                <svg width="14" height="14" fill="none" stroke="var(--cyan)" stroke-width="2.5" viewBox="0 0 24 24" style="flex-shrink:0;"><path d="M9 11l3 3L22 4"/></svg>
                <span style="font-size:.875rem;font-weight:600;color:#0f172a;">{p}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="reveal-element delay-200">
          <!-- Avantages card -->
          <div style="background:linear-gradient(135deg,#0a0f1e,#0d1a3a);border-radius:1.25rem;padding:2rem;margin-bottom:1.5rem;">
            <h3 style="color:white;font-weight:700;font-size:1.125rem;margin:0 0 1.25rem;">Pourquoi choisir Meridian ?</h3>
            {metier.avantages.map(a => (
              <div style="display:flex;align-items:center;gap:.875rem;padding:.75rem 0;border-bottom:1px solid rgba(255,255,255,.08);">
                <span style="width:28px;height:28px;background:rgba(0,229,255,.15);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                  <svg width="12" height="12" fill="none" stroke="var(--cyan)" stroke-width="2.5" viewBox="0 0 24 24"><path d="M9 11l3 3L22 4"/></svg>
                </span>
                <span style="color:rgba(255,255,255,.8);font-size:.875rem;">{a}</span>
              </div>
            ))}
          </div>
          <!-- Certifications -->
          <div style="background:#f8fafc;border-radius:1rem;padding:1.5rem;">
            <p style="font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.2em;color:#94a3b8;margin:0 0 1rem;">Certifications</p>
            <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
              {metier.certifications.map(c => (
                <span style="padding:.375rem .875rem;background:white;border:1.5px solid #e2e8f0;border-radius:9999px;font-size:.8rem;font-weight:700;color:#0f172a;">✓ {c}</span>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Zones d'intervention -->
  <section class="section" style="background:#f8fafc;">
    <div class="container">
      <div style="text-align:center;margin-bottom:2.5rem;" class="reveal-element">
        <div class="section-label" style="justify-content:center;">Zones desservies</div>
        <h2 style="font-size:clamp(1.75rem,3vw,2.25rem);font-weight:800;color:#0f172a;margin:0;">
          {metier.nomCourt} en Occitanie
        </h2>
      </div>
      <div style="display:flex;flex-wrap:wrap;gap:.625rem;justify-content:center;" class="reveal-element">
        {villes.map(v => (
          <a href={`/villes/${v.slug}`} style="padding:.5rem 1rem;background:white;border:1.5px solid #e2e8f0;border-radius:9999px;font-size:.8125rem;font-weight:600;color:#374151;text-decoration:none;transition:all .2s;" onmouseover="this.style.borderColor='var(--cyan)';this.style.color='var(--electric)'" onmouseout="this.style.borderColor='#e2e8f0';this.style.color='#374151'">{v.nom}</a>
        ))}
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>

<style>
@media(min-width:1024px){ .metier-detail-grid { grid-template-columns: 3fr 2fr !important; } }
</style>
