---
import BaseLayout from '../layouts/BaseLayout.astro'
import Breadcrumb from '../components/Breadcrumb.astro'
import CtaSection from '../components/CtaSection.astro'

const offres = [
  { titre: 'Chef de chantier BTP', type: 'CDI', lieu: 'Montpellier', exp: '5+ ans', desc: 'Pilotage de chantiers construction neuve et rénovation, encadrement équipes.' },
  { titre: 'Maçon qualifié N3', type: 'CDI', lieu: 'Nîmes', exp: '3+ ans', desc: 'Travaux de maçonnerie traditionnelle et béton armé sur chantiers résidentiels.' },
  { titre: 'Couvreur zingueur', type: 'CDI', lieu: 'Montpellier', exp: '2+ ans', desc: 'Pose et réfection toitures tuiles, zinc, ardoises. Travaux en hauteur.' },
  { titre: 'Technicien isolation RGE', type: 'CDI', lieu: 'Béziers', exp: '2+ ans', desc: 'ITI, ITE, combles. Habilitation RGE souhaitée. Formation interne possible.' },
  { titre: 'Peintre en bâtiment', type: 'CDI', lieu: 'Montpellier', exp: '1+ an', desc: 'Peinture intérieure et extérieure, revêtements muraux, protection surfaces.' },
  { titre: 'Chargé d\'affaires BTP', type: 'CDI', lieu: 'Montpellier', exp: '5+ ans', desc: 'Développement commercial, chiffrage, suivi clients. Secteur résidentiel/tertiaire.' },
]
---

<BaseLayout
  title="Recrutement — Rejoignez Meridian Groupe | Emploi BTP Occitanie"
  description="Rejoignez les 45 collaborateurs de Meridian Groupe. Offres d'emploi BTP en Occitanie : maçon, chef de chantier, couvreur, isolateur, peintre. CDI, formation continue."
>
  <div class="page-hero">
    <div class="container" style="position:relative;z-index:1;">
      <Breadcrumb items={[{ label: 'Recrutement' }]} />
      <div style="max-width:680px;margin-top:2rem;">
        <div class="shimmer-badge" style="margin-bottom:1.25rem;display:inline-flex;">{offres.length} postes ouverts</div>
        <h1 style="color:white;font-size:clamp(2.25rem,5vw,3.75rem);font-weight:900;margin:0 0 1.25rem;line-height:1.1;">
          Rejoignez<br/>
          <span style="background:linear-gradient(135deg,#00e5ff,#0066ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">l'équipe Meridian</span>
        </h1>
        <p style="color:rgba(255,255,255,.75);font-size:1.0625rem;max-width:540px;line-height:1.7;">
          Intégrez un groupe BTP régional en pleine croissance. Ambiance familiale, projets ambitieux, formation continue et évolution de carrière.
        </p>
      </div>
    </div>
  </div>

  <!-- Why join us -->
  <section class="section" style="background:linear-gradient(135deg,#00e5ff,#0066ff);">
    <div class="container">
      <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:2rem;text-align:center;" class="avantages-grid">
        {[
          { emoji: '📈', titre: 'Évolution garantie', desc: 'Parcours de formation et plan de carrière individualisé.' },
          { emoji: '🏡', titre: 'Vie locale', desc: 'Chantiers en Occitanie, pas de grands déplacements.' },
          { emoji: '💪', titre: 'Équipe soudée', desc: 'Ambiance familiale, 45 collègues passionnés.' },
          { emoji: '💶', titre: 'Rémunération attractive', desc: 'Salaire compétitif + primes + mutuelle Pro BTP.' },
        ].map(a => (
          <div class="reveal-element" style="padding:2rem;background:rgba(10,15,30,.15);border-radius:1rem;backdrop-filter:blur(8px);">
            <div style="font-size:2rem;margin-bottom:.75rem;">{a.emoji}</div>
            <h3 style="color:#0a0f1e;font-weight:700;font-size:1.0625rem;margin:0 0 .5rem;">{a.titre}</h3>
            <p style="color:rgba(10,15,30,.7);font-size:.875rem;margin:0;">{a.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Offres -->
  <section class="section" style="background:#f8fafc;">
    <div class="container">
      <div style="text-align:center;margin-bottom:3rem;" class="reveal-element">
        <div class="section-label" style="justify-content:center;">Nos offres d'emploi</div>
        <h2 style="font-size:clamp(1.875rem,3.5vw,2.5rem);font-weight:800;color:#0f172a;margin:0;">Postes disponibles</h2>
      </div>
      <div style="display:flex;flex-direction:column;gap:1rem;">
        {offres.map((o, i) => (
          <div class="reveal-element" style={`display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1.5rem;padding:2rem;background:white;border-radius:1rem;border:1.5px solid #f1f5f9;transition:all .3s;transition-delay:${i*60}ms;`} onmouseover="this.style.borderColor='var(--cyan)';this.style.transform='translateX(4px)'" onmouseout="this.style.borderColor='#f1f5f9';this.style.transform=''">
            <div style="flex:1;min-width:200px;">
              <h3 style="font-weight:700;color:#0f172a;font-size:1.0625rem;margin:0 0 .375rem;">{o.titre}</h3>
              <p style="color:#374151;font-size:.875rem;margin:0 0 .625rem;">{o.desc}</p>
              <div style="display:flex;flex-wrap:wrap;gap:.5rem;">
                <span style="padding:.25rem .75rem;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:9999px;font-size:.7rem;font-weight:700;color:#16a34a;">{o.type}</span>
                <span style="padding:.25rem .75rem;background:#eff6ff;border:1px solid #bfdbfe;border-radius:9999px;font-size:.7rem;font-weight:700;color:#2563eb;">{o.lieu}</span>
                <span style="padding:.25rem .75rem;background:#f8fafc;border:1px solid #e2e8f0;border-radius:9999px;font-size:.7rem;font-weight:600;color:#374151;">{o.exp}</span>
              </div>
            </div>
            <a href="mailto:recrutement@meridian-groupe.fr?subject=Candidature - {o.titre}" class="btn-gradient" style="flex-shrink:0;">
              Postuler
            </a>
          </div>
        ))}
      </div>

      <!-- Spontaneous application -->
      <div style="margin-top:3rem;padding:3rem;background:linear-gradient(135deg,#0a0f1e,#0d1a3a);border-radius:1.5rem;text-align:center;" class="reveal-element">
        <h3 style="color:white;font-size:1.375rem;font-weight:700;margin:0 0 .875rem;">Candidature spontanée</h3>
        <p style="color:rgba(255,255,255,.65);max-width:500px;margin:0 auto 2rem;line-height:1.7;">
          Votre profil ne correspond pas à nos offres actuelles ? Envoyez-nous votre CV, nous gardons les bons profils en mémoire.
        </p>
        <a href="mailto:recrutement@meridian-groupe.fr" class="btn-gradient">
          Envoyer ma candidature
        </a>
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>

<style>
@media(min-width:768px){ .avantages-grid { grid-template-columns: repeat(4,1fr) !important; } }
</style>
