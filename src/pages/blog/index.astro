---
import BaseLayout from '../../layouts/BaseLayout.astro'
import Breadcrumb from '../../components/Breadcrumb.astro'
import CtaSection from '../../components/CtaSection.astro'
import { articles } from '../../data/blog'

const featured = articles.find(a => a.featured)!
const rest = articles.filter(a => !a.featured)
---

<BaseLayout
  title="Blog BTP — Conseils construction & rénovation | Meridian Groupe"
  description="Conseils d'experts BTP : isolation, couverture, construction bioclimatique, rénovation énergétique. Le blog de Meridian Groupe, leaders en Occitanie depuis 1998."
>
  <div class="page-hero">
    <div class="container" style="position:relative;z-index:1;">
      <Breadcrumb items={[{ label: 'Blog' }]} />
      <div style="max-width:600px;margin-top:2rem;">
        <div class="section-label">Conseils d'experts</div>
        <h1 style="color:white;font-size:clamp(2.25rem,5vw,3.75rem);font-weight:900;margin:0 0 1rem;line-height:1.1;">
          Blog <span style="background:linear-gradient(135deg,#00e5ff,#0066ff);-webkit-background-clip:text;-webkit-text-fill-color:transparent;">Meridian</span>
        </h1>
        <p style="color:rgba(255,255,255,.75);font-size:1.0625rem;line-height:1.7;">
          Conseils pratiques, actualités réglementaires et guides techniques par nos experts BTP.
        </p>
      </div>
    </div>
  </div>

  <section class="section" style="background:#f8fafc;">
    <div class="container">
      <!-- Featured -->
      <div class="reveal-element" style="margin-bottom:4rem;">
        <div class="section-label">Article à la une</div>
        <article style="display:grid;grid-template-columns:1fr;background:white;border-radius:1.5rem;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,.06);" class="featured-article">
          <a href={`/blog/${featured.slug}`} style="display:block;overflow:hidden;height:320px;">
            <img src={featured.image} alt={featured.titre} loading="eager" fetchpriority="high" style="width:100%;height:100%;object-fit:cover;transition:transform .6s;" onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform=''" />
          </a>
          <div style="padding:3rem;">
            <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:1.25rem;">
              <span style="padding:.3rem .875rem;background:linear-gradient(135deg,rgba(0,229,255,.1),rgba(0,102,255,.08));border:1px solid rgba(0,229,255,.2);border-radius:9999px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--electric);">{featured.categorie}</span>
              <span style="font-size:.8rem;color:#94a3b8;">{featured.tempsLecture} min de lecture</span>
              <span style="font-size:.8rem;color:#94a3b8;">{featured.date}</span>
            </div>
            <h2 class="h2-serif" style="font-size:clamp(1.5rem,3vw,2.25rem);color:#0f172a;margin:0 0 1rem;line-height:1.3;">
              <a href={`/blog/${featured.slug}`} style="text-decoration:none;color:inherit;transition:color .2s;" onmouseover="this.style.color='var(--electric)'" onmouseout="this.style.color='inherit'">{featured.titre}</a>
            </h2>
            <p style="color:#374151;font-size:1rem;line-height:1.75;margin:0 0 2rem;">{featured.extrait}</p>
            <div style="display:flex;align-items:center;justify-content:space-between;">
              <div style="display:flex;align-items:center;gap:.875rem;">
                <img src={featured.auteurPhoto} alt={featured.auteur} loading="lazy" style="width:40px;height:40px;border-radius:50%;object-fit:cover;" />
                <div>
                  <div style="font-weight:700;color:#0f172a;font-size:.875rem;">{featured.auteur}</div>
                  <div style="font-size:.75rem;color:#94a3b8;">{featured.auteurRole}</div>
                </div>
              </div>
              <a href={`/blog/${featured.slug}`} class="btn-gradient" style="padding:.625rem 1.5rem;font-size:.875rem;">
                Lire l'article →
              </a>
            </div>
          </div>
        </article>
      </div>

      <!-- All articles -->
      <div class="section-label" style="margin-bottom:2rem;">Tous les articles</div>
      <div style="display:grid;grid-template-columns:1fr;gap:2rem;" class="articles-grid">
        {rest.map((art, i) => (
          <article class="reveal-element" style={`background:white;border-radius:1.25rem;overflow:hidden;transition:transform .3s,box-shadow .3s;transition-delay:${i*80}ms;`} onmouseover="this.style.transform='translateY(-4px)';this.style.boxShadow='0 16px 50px rgba(0,0,0,.09)'" onmouseout="this.style.transform='';this.style.boxShadow=''">
            <a href={`/blog/${art.slug}`} style="display:block;overflow:hidden;height:200px;">
              <img src={art.image} alt={art.titre} loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform .5s;" onmouseover="this.style.transform='scale(1.06)'" onmouseout="this.style.transform=''"/>
            </a>
            <div style="padding:1.75rem;">
              <div style="display:flex;align-items:center;gap:.625rem;margin-bottom:.875rem;">
                <span style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.12em;color:var(--electric);">{art.categorie}</span>
                <span style="color:#e2e8f0;">·</span>
                <span style="font-size:.75rem;color:#94a3b8;">{art.tempsLecture} min</span>
              </div>
              <h3 style="font-weight:700;color:#0f172a;font-size:1.0625rem;margin:0 0 .625rem;line-height:1.4;">
                <a href={`/blog/${art.slug}`} style="text-decoration:none;color:inherit;transition:color .2s;" onmouseover="this.style.color='var(--electric)'" onmouseout="this.style.color='inherit'">{art.titre}</a>
              </h3>
              <p style="color:#374151;font-size:.875rem;line-height:1.65;margin:0 0 1.25rem;">{art.extrait.slice(0,140)}…</p>
              <div style="display:flex;align-items:center;justify-content:space-between;">
                <div style="display:flex;align-items:center;gap:.625rem;">
                  <img src={art.auteurPhoto} alt={art.auteur} loading="lazy" style="width:30px;height:30px;border-radius:50%;object-fit:cover;" />
                  <span style="font-size:.8rem;color:#94a3b8;">{art.auteur} · {art.date}</span>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
  <CtaSection />
</BaseLayout>

<style>
@media(min-width:1024px){ .featured-article { grid-template-columns: 1fr 1fr !important; } }
@media(min-width:640px){ .articles-grid { grid-template-columns: repeat(2,1fr) !important; } }
@media(min-width:1024px){ .articles-grid { grid-template-columns: repeat(3,1fr) !important; } }
</style>
